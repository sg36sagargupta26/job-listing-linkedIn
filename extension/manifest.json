{
  "manifest_version": 3,
  "name": "LinkedIn Job Matcher",
  "version": "1.0.0",
  "description": "AI-powered CV matching for LinkedIn job postings. Save matches to Google Sheets.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.deepseek.com/*",
    "https://script.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/view/*"],
      "js": ["cv-data.js", "content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
